class Solution {
public:
    ListNode* partition(ListNode* head, int x) {
        ListNode afternode(0);
        ListNode beforenode(0);
        ListNode* after = &afternode;
        ListNode* before = &beforenode;
        while(head){
            if(head->val < x){
                before->next =  head;
                before = before->next;
            }
            else{
                after->next= head;
                after = after->next;
            }
            head=head->next;
        }
        after->next = NULL;
        before->next = afternode.next;
        return beforenode.next;
    }
    
};
