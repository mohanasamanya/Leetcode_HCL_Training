class Solution {
public:
    int minOperations(vector<int>& nums) {
        stack<int> s;
        int operations = 0;

        for (int x : nums) {
            while (!s.empty() && s.top() > x) {
                s.pop();
            }

            if (x > 0 && (s.empty() || s.top() < x)) {
                s.push(x);
                operations++;
            }
        }

        return operations;
    }
};
